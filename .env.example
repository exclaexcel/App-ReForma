# App ReForma - Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com seus valores

# Supabase
NEXT_PUBLIC_SUPABASE_URL=seu_url_do_supabase_aqui
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anonima_aqui

# (Opcional) Se usar com backend próprio depois:
# SUPABASE_SERVICE_ROLE_KEY=sua_chave_de_servico_aqui

# E2E Tests (Playwright)
E2E_EMAIL=usuario-teste@exemplo.com
E2E_PASSWORD=senha-teste-segura
PLAYWRIGHT_BASE_URL=http://localhost:3000
PLAYWRIGHT_RUN_ID=
SUPABASE_SERVICE_ROLE_KEY=
